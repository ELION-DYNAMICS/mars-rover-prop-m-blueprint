{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mars-rover-prop-m-blueprint.local/schemas/run_metadata.schema.json",
  "title": "Run Metadata Schema",
  "description": "Schema for dataset run metadata. Used for simulation and calibration traceability. Timestamps must be UTC ISO-8601 (e.g., 2026-02-22T03:15:00Z). SI units only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "created_utc",
    "mode",
    "backend",
    "scenario",
    "seed",
    "git",
    "clock",
    "physics",
    "robot",
    "params",
    "topics",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Schema version for this metadata format."
    },
    "run_id": {
      "type": "string",
      "minLength": 8,
      "description": "Unique run identifier, recommended format: YYYYMMDD_HHMMSS_<scenario>_<git_short_hash>."
    },
    "created_utc": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp when the run was created."
    },
    "mode": {
      "type": "string",
      "enum": ["simulation", "hardware"],
      "description": "Execution mode."
    },
    "backend": {
      "type": "string",
      "enum": ["gazebo", "webots", "pybullet", "hardware"],
      "description": "Execution backend. Use 'hardware' for physical runs."
    },
    "scenario": {
      "type": "string",
      "minLength": 1,
      "description": "Scenario/world identifier (e.g., mars_flat, lander_tether_site)."
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "description": "Deterministic seed used for simulation randomness. Use 0 for hardware unless you intentionally inject stochasticity."
    },

    "operator": {
      "type": ["string", "null"],
      "description": "Optional: operator name/handle for the run."
    },
    "notes": {
      "type": ["string", "null"],
      "description": "Optional: short free-form notes."
    },

    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "dirty"],
      "properties": {
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,40}$",
          "description": "Git commit hash."
        },
        "dirty": {
          "type": "boolean",
          "description": "True if working tree had uncommitted changes at run time."
        },
        "branch": {
          "type": ["string", "null"],
          "description": "Optional: branch name."
        },
        "repo_url": {
          "type": ["string", "null"],
          "description": "Optional: repository URL."
        }
      }
    },

    "clock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["use_sim_time", "time_source"],
      "properties": {
        "use_sim_time": {
          "type": "boolean",
          "description": "True if /clock simulated time is used."
        },
        "time_source": {
          "type": "string",
          "enum": ["sim_clock", "system_clock", "ros_time"],
          "description": "Source of timestamps used by nodes."
        }
      }
    },

    "physics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["time_step_s", "real_time_factor", "engine"],
      "properties": {
        "engine": {
          "type": "string",
          "description": "Physics engine identifier (e.g., gz-dart, gz-tpe, webots, pybullet)."
        },
        "engine_version": {
          "type": ["string", "null"],
          "description": "Optional: physics engine version string."
        },
        "time_step_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Physics step size in seconds."
        },
        "real_time_factor": {
          "type": "number",
          "minimum": 0,
          "description": "Real-time factor (1.0 = real time). For headless regression, fixed-step is recommended."
        },
        "deterministic": {
          "type": ["boolean", "null"],
          "description": "Optional: whether deterministic stepping is enabled."
        }
      }
    },

    "robot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "urdf_sha256", "base_frame"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Robot model name."
        },
        "urdf_sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$",
          "description": "SHA-256 hash of the URDF/Xacro used to generate the robot model."
        },
        "base_frame": {
          "type": "string",
          "minLength": 1,
          "description": "Base frame id, typically base_link."
        }
      }
    },

    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_config",
        "estimator_config",
        "terramechanics_config",
        "nav2_profile"
      ],
      "properties": {
        "control_config": {
          "type": "string",
          "minLength": 1,
          "description": "Path to control configuration YAML used for this run."
        },
        "estimator_config": {
          "type": "string",
          "minLength": 1,
          "description": "Path to estimator configuration YAML used for this run."
        },
        "terramechanics_config": {
          "type": "string",
          "minLength": 1,
          "description": "Path to terramechanics configuration YAML used for this run."
        },
        "nav2_profile": {
          "type": ["string", "null"],
          "description": "Path to Nav2 profile YAML (null if Nav2 not used)."
        },
        "extra_configs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional: additional config files applied at runtime."
        }
      }
    },

    "topics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recorded"],
      "properties": {
        "recorded": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "List of recorded topic names in the run bag (MCAP)."
        },
        "expected": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional: topics expected by scenario/ICD."
        }
      }
    },

    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mcap", "metrics_json"],
      "properties": {
        "mcap": {
          "type": "string",
          "minLength": 1,
          "description": "Path to MCAP bag for the run."
        },
        "metrics_json": {
          "type": ["string", "null"],
          "description": "Path to metrics.json if generated (may be null early in bring-up)."
        },
        "plots_dir": {
          "type": ["string", "null"],
          "description": "Optional: path to generated plots directory."
        }
      }
    },

    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mcap_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]{64}$",
          "description": "Optional: SHA-256 of MCAP file."
        },
        "metadata_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]{64}$",
          "description": "Optional: SHA-256 of this run_metadata.json file."
        }
      }
    }
  }
}
